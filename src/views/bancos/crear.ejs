<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Crear Banco de Preguntas</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %> 
    <main class="main-content">
        <div class="card" style="max-width: 600px; margin: 0 auto;">
            <h2 style="color: var(--primary); margin-bottom: 1.5rem;">Nuevo Banco de Preguntas</h2>
            <form action="/bancos/crear" method="POST">
                <div class="form-group">
                    <label>Título del Banco:</label>
                    <input type="text" name="titulo" placeholder="Ej: Entrevista Técnica de Node.js" required>
                </div>
                
                <div class="form-group">
                    <label>Descripción:</label>
                    <textarea name="descripcion" placeholder="Breve descripción del tema a evaluar..." style="min-height: 100px; resize: vertical;"></textarea>
                </div>
                
                <div class="form-group">
                    <label>Categoría Técnica:</label>
                    <input type="text" name="categoria" placeholder="Ej: Desarrollo Web, Bases de Datos, DevOps..." required>
                </div>

                <div style="margin-top: 2rem;">
                    <button type="submit" style="background-color: var(--success);">Crear Simulador</button>
                    <a href="/dashboard" class="btn btn-secondary mt-1 text-center" style="display: block; margin-top: 0.75rem;">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>