<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resolver Reto - <%= reto.titulo %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .editor-container {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }
        .left-panel { flex: 1; }
        .right-panel { flex: 1; display: flex; flex-direction: column; }
        .code-area { 
            width: 100%; 
            height: 300px; 
            font-family: monospace; 
            font-size: 16px; 
            padding: 10px;
            background: #282c34;
            color: #abb2bf;
            border-radius: 5px;
            resize: vertical;
        }
        .console {
            background: #1e1e1e;
            color: #00ff00;
            padding: 15px;
            font-family: monospace;
            border-radius: 5px;
            min-height: 100px;
            margin-top: 15px;
            white-space: pre-wrap;
            overflow-y: auto;
            max-height: 300px;
        }
        .error { color: #ff5555; }
        .btn-run {
            background: #4caf50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            font-size: 1.1em;
            cursor: pointer;
            margin-right: 10px;
        }
        .btn-run:hover { background: #45a049; }
        .btn-reset {
            background: #6c757d;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            font-size: 1.1em;
            cursor: pointer;
        }
        .btn-reset:hover { background: #5a6268; }
        .btn-pista {
            background: #17a2b8;
            color: white;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            font-size: 0.9em;
            cursor: pointer;
            margin-top: 10px;
        }
        .reto-details {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 5px;
            border-left: 5px solid var(--primary-color);
        }
        .dificultad {
            padding: 5px 10px; border-radius: 5px; font-weight: bold;
        }
        .dif-fácil { background: #d4edda; color: #155724; }
        .dif-medio { background: #fff3cd; color: #856404; }
        .dif-difícil { background: #f8d7da; color: #721c24; }
        
        .header-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        .badge-puntos {
            background: #ffeeba;
            color: #856404;
            padding: 5px 10px;
            border-radius: 5px;
            font-weight: bold;
        }
        .badge-intentos {
            background: #e2e3e5;
            color: #383d41;
            padding: 5px 10px;
            border-radius: 5px;
            font-weight: bold;
        }
        .test-cases-list {
            margin-top: 15px;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 5px;
        }
        .test-case-item {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }
        .test-case-item:last-child {
            border-bottom: none;
        }
        .test-case-item code {
            background: #f1f1f1;
            padding: 2px 5px;
            border-radius: 3px;
        }
        .leaderboard {
            margin-top: 20px;
            background: white;
            padding: 15px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }
        #pista-box {
            display: none;
            background: #e9ecef;
            padding: 10px;
            border-radius: 5px;
            margin-top: 10px;
            border-left: 4px solid #17a2b8;
        }
        .btn-volver {
            display: inline-block;
            background: #e9ecef;
            color: #333;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background 0.2s;
            margin-bottom: 15px;
        }
        .btn-volver:hover {
            background: #ced4da;
            color: #000;
        }
        .btn-group {
            margin-top: 10px;
            display: flex;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container" style="max-width: 1200px;">
        <div class="editor-container">
            <div class="left-panel">
                <div class="reto-details">
                    <a href="/retos" class="btn-volver">← Volver a Retos</a>
                    
                    <div class="header-meta">
                        <span class="dificultad dif-<%= reto.dificultad.toLowerCase() %>"><%= reto.dificultad %></span>
                        <span class="badge-puntos">🏆 <%= reto.puntos %> Puntos</span>
                        <span class="badge-intentos">🔄 Tus intentos: <%= typeof intentosTotales !== 'undefined' ? intentosTotales : 0 %></span>
                    </div>
                    
                    <form action="/retos/calificar" method="POST" style="background:#fff; padding:10px; border-radius:5px; border:1px solid #eee; display:inline-block; margin-bottom:15px;">
                        <input type="hidden" name="reto_id" value="<%= reto.id %>">
                        <label style="font-weight:bold; margin-right:10px; font-size:0.9em;">Calificar reto:</label>
                        <select name="estrellas" style="padding:3px; border-radius:3px;">
                            <option value="5">5 ⭐ Excelente</option>
                            <option value="4">4 ⭐ Muy bueno</option>
                            <option value="3">3 ⭐ Bueno</option>
                            <option value="2">2 ⭐ Regular</option>
                            <option value="1">1 ⭐ Malo</option>
                        </select>
                        <button type="submit" style="background:#28a745; color:white; border:none; padding:5px 10px; border-radius:4px; font-size:0.8em; cursor:pointer;">Votar</button>
                    </form>
                    
                    <h2><%= reto.titulo %></h2>
                    <p style="font-size: 1.1em;"><%= reto.enunciado %></p>
                    
                    <% if (reto.pista) { %>
                        <button class="btn-pista" onclick="togglePista()">💡 Ver Pista</button>
                        <div id="pista-box">
                            <strong>Pista:</strong> <%= reto.pista %>
                        </div>
                    <% } %>

                    <hr>
                    
                    <h4>Casos de Prueba</h4>
                    <div class="test-cases-list">
                        <% if(typeof casosPrueba !== 'undefined' && casosPrueba && casosPrueba.length > 0) { %>
                            <% const visibles = casosPrueba.filter(c => c.es_visible === 1); %>
                            <% if (visibles.length > 0) { %>
                                <% visibles.forEach((test, idx) => { %>
                                    <div class="test-case-item">
                                        <strong>Caso Visible #<%= idx + 1 %>:</strong><br>
                                        Input: <code class="test-input-code"><%= test.input %></code><br>
                                        Output Esperado: <code class="test-output-code"><%= test.output_esperado %></code>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="test-case-item">No hay casos visibles parametrizados.</div>
                            <% } %>
                        <% } else { %>
                            <!-- Retrocompatibilidad si aún no hay insertados -->
                            <div class="test-case-item">
                                <strong>Ejemplo:</strong><br>
                                Input: <code><%= reto.test_input %></code><br>
                                Output Esperado: <code><%= reto.test_output %></code>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="leaderboard">
                    <h3>🎖️ Top 5 Soluciones Exitosas</h3>
                    <ul>
                        <% if(leaderboard.length === 0) { %>
                            <li>Aún nadie ha resuelto este reto. ¡Sé el primero!</li>
                        <% } %>
                        <% leaderboard.forEach((l, i) => { %>
                            <li><strong>#<%= i+1 %></strong> <%= l.nombre %> - <%= new Date(l.fecha).toLocaleString() %></li>
                        <% }) %>
                    </ul>
                </div>
            </div>

            <div class="right-panel">
                <h3>Tu Código (<%= reto.lenguaje %>)</h3>
                <textarea id="codeEditor" class="code-area"><%= reto.codigo_inicial %></textarea>
                
                <div class="btn-group">
                    <button class="btn-run" onclick="runCode()">▶ Ejecutar Pruebas</button>
                    <button class="btn-reset" onclick="resetCode()">🔄 Resetear código</button>
                </div>

                <div id="consoleOutput" class="console">>_ Esperando ejecución...</div>
            </div>
        </div>
    </div>

    <!-- Lógica de ejecución evaluador múltiple -->
    <script>
        const retoId = <%= reto.id %>;
        // Inyectamos el string de código inicial original
        const rawInitialCode = <%- JSON.stringify(reto.codigo_inicial || '') %>;
        
        // Array de casos de prueba extraídos desde la Base de Datos
        const casosPrueba = <%- JSON.stringify(casosPrueba || []) %>;
        
        // Variables de retrocompatibilidad
        const defaultInput = <%- JSON.stringify(reto.test_input || '') %>;
        const defaultOutput = <%- JSON.stringify(reto.test_output || '') %>;

        function togglePista() {
            const x = document.getElementById("pista-box");
            x.style.display = (x.style.display === "block") ? "none" : "block";
        }

        function resetCode() {
            if (confirm("¿Estás seguro que deseas restablecer tu código? Perderás los cambios manuales.")) {
                document.getElementById('codeEditor').value = rawInitialCode;
                document.getElementById('consoleOutput').innerHTML = ">_ Código restablecido.\n";
            }
        }

        async function runCode() {
            const code = document.getElementById('codeEditor').value;
            const consoleDiv = document.getElementById('consoleOutput');
            
            consoleDiv.innerHTML = ">_ Validando sintaxis y ejecutando pruebas...\n";

            let allTestsPassed = true;
            let testsToRun = [];

            // Usamos la tabla nueva de casos si existe para el reto
            if (casosPrueba && casosPrueba.length > 0) {
                testsToRun = casosPrueba;
            } else if (defaultInput) {
                // Modo antiguo (si no hay casos parametrizados)
                testsToRun = [{ input: defaultInput, output_esperado: defaultOutput, es_visible: 1 }];
            }

            if (testsToRun.length === 0) {
                consoleDiv.innerHTML += "\n⚠️ No hay casos de prueba definidos en la base de datos para evaluar.";
                return;
            }

            try {
                // Compilación (eval frontend) de la función del usuario
                let funcionUsuario;
                eval(`funcionUsuario = ${code}`);

                if (typeof funcionUsuario !== 'function') {
                    throw new Error("El código debe definir una función válida.");
                }

                let executionOutput = "\n--- RESULTADOS ---\n";
                let visibleCount = 1;
                let hiddenCount = 1;

                const globalStart = performance.now();

                // Iteramos TODOS los casos, tanto visibles como ocultos (es_visible 1 o 0)
                for (const test of testsToRun) {
                    try {
                        const argsString = `[${test.input}]`;
                        // Evaluar dinámicamente los argumentos para desglosarlos correctamente
                        const argsArray = eval(argsString);

                        const result = funcionUsuario(...argsArray);
                        const resultString = typeof result === 'string' ? `"${result}"` : String(result);
                        
                        // Comparación: el admin puede ingresarlo como "10" o 10
                        const isMatch = (String(result) === String(test.output_esperado) || 
                                         JSON.stringify(result) === test.output_esperado ||
                                         resultString === test.output_esperado);

                        if (!isMatch) {
                            allTestsPassed = false;
                        }

                        // Formatear consola según sea visible o oculto
                        if (test.es_visible === 1) {
                            const icon = isMatch ? "✅" : "❌";
                            executionOutput += `${icon} Test ${visibleCount}: Input: ${test.input} | Esperado: ${test.output_esperado} | Obtenido: ${resultString}\n`;
                            visibleCount++;
                        } else {
                            if (!isMatch) {
                                executionOutput += `❌ Test Oculto ${hiddenCount} falló.\n`;
                            }
                            hiddenCount++;
                        }
                    } catch (evalErr) {
                        allTestsPassed = false;
                        if (test.es_visible === 1) {
                            executionOutput += `❌ Test Visible ${visibleCount} falló con error: ${evalErr.message}\n`;
                            visibleCount++;
                        } else {
                            executionOutput += `❌ Test Oculto ${hiddenCount} falló con error de ejecución.\n`;
                            hiddenCount++;
                        }
                    }
                }

                const globalEnd = performance.now();
                const totalTime = (globalEnd - globalStart).toFixed(2);

                consoleDiv.innerHTML += executionOutput;

                if (allTestsPassed) {
                    consoleDiv.innerHTML += `\n🎉 ¡EL CÓDIGO PASÓ TODAS LAS PRUEBAS! (${totalTime}ms) 🎉\n`;
                } else {
                    consoleDiv.innerHTML += `\n⚠️ Fallaste algunas pruebas. Revisa tu intento.\n`;
                }

                // POST asíncrono pasaron todos (Exitoso) o falló (Fallido)
                await fetch('/retos/enviar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reto_id: retoId,
                        codigo: code,
                        resultado: allTestsPassed ? 'Exitoso' : 'Fallido'
                    })
                });

                // Recargar si fue exitoso para actualizar badges y leaderboards
                if (allTestsPassed) {
                    setTimeout(() => { window.location.reload(); }, 2000);
                }

            } catch (err) {
                consoleDiv.innerHTML += `\n❌ ERROR DE SINTAXIS O COMPILACIÓN:\n${err.message}`;
                
                // Penalización como intento fallido si ni compila
                await fetch('/retos/enviar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reto_id: retoId, codigo: code, resultado: 'Fallido' })
                });
            }
        }
    </script>
</body>
</html>