<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resolver Reto - <%= reto.titulo %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .editor-container {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }
        .left-panel { flex: 1; display: flex; flex-direction: column; gap: 16px; }
        .right-panel { flex: 1; display: flex; flex-direction: column; gap: 16px; }
        
        .header-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .btn-group {
            margin-top: 10px;
            display: flex;
            gap: 10px;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container">
        <div class="editor-container">
            <div class="left-panel">
                <div class="card banco-detalles">
                    <a href="/retos" class="btn-volver">← Volver a Retos</a>
                    
                    <div class="header-meta">
                        <span class="badge badge-<%= reto.dificultad.replace('í', 'i') %>"><%= reto.dificultad %></span>
                        <span class="badge badge-Exitoso">🏆 <%= reto.puntos %> Puntos</span>
                        <span class="badge badge-Medio">🔄 Tus intentos: <%= typeof intentosTotales !== 'undefined' ? intentosTotales : 0 %></span>
                    </div>
                    
                    <form action="/retos/calificar" method="POST" class="auth-card" style="padding: 12px; margin-bottom: 20px; display: inline-block;">
                        <input type="hidden" name="reto_id" value="<%= reto.id %>">
                        <label style="font-weight:bold; margin-right:10px; font-size:0.9em; display: inline-block;">Calificar reto:</label>
                        <select name="estrellas" style="width: auto; padding: 4px 8px; margin-right: 10px;">
                            <option value="5">5 ⭐ Excelente</option>
                            <option value="4">4 ⭐ Muy bueno</option>
                            <option value="3">3 ⭐ Bueno</option>
                            <option value="2">2 ⭐ Regular</option>
                            <option value="1">1 ⭐ Malo</option>
                        </select>
                        <button type="submit" class="btn" style="width: auto; padding: 4px 12px;">Votar</button>
                    </form>
                    
                    <h2><%= reto.titulo %></h2>
                    <p class="descripcion" style="font-size: 14px;"><%= reto.enunciado %></p>
                    
                    <% if (reto.pista) { %>
                        <button class="btn-secondary" onclick="togglePista()">💡 Ver Pista</button>
                        <div id="pista-box" class="casos-container" style="display: none; margin-top: 10px;">
                            <strong>Pista:</strong> <%= reto.pista %>
                        </div>
                    <% } %>

                    <hr>
                    
                    <h3>Casos de Prueba</h3>
                    <div class="test-cases-list">
                        <% if(typeof casosPrueba !== 'undefined' && casosPrueba && casosPrueba.length > 0) { %>
                            <% const visibles = casosPrueba.filter(c => c.es_visible === 1); %>
                            <% if (visibles.length > 0) { %>
                                <% visibles.forEach((test, idx) => { %>
                                    <div class="test-case-item">
                                        <strong>Caso Visible #<%= idx + 1 %>:</strong><br>
                                        Input: <code class="test-input-code"><%= test.input %></code><br>
                                        Output Esperado: <code class="test-output-code"><%= test.output_esperado %></code>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="test-case-item">No hay casos visibles parametrizados.</div>
                            <% } %>
                        <% } else { %>
                            <!-- Retrocompatibilidad si aún no hay insertados -->
                            <div class="test-case-item">
                                <strong>Ejemplo:</strong><br>
                                Input: <code><%= reto.test_input %></code><br>
                                Output Esperado: <code><%= reto.test_output %></code>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="leaderboard">
                    <h3>🎖️ Top 5 Soluciones Exitosas</h3>
                    <ul>
                        <% if(leaderboard.length === 0) { %>
                            <li>Aún nadie ha resuelto este reto. ¡Sé el primero!</li>
                        <% } %>
                        <% leaderboard.forEach((l, i) => { %>
                            <li><strong>#<%= i+1 %></strong> <%= l.nombre %> - <%= new Date(l.fecha).toLocaleString() %></li>
                        <% }) %>
                    </ul>
                </div>
            </div>

            <div class="right-panel">
                <h3>Tu Código (<%= reto.lenguaje %>)</h3>
                <textarea id="codeEditor" class="code-area"><%= reto.codigo_inicial %></textarea>
                
                <div class="btn-group">
                    <button class="btn-run" onclick="runCode()">▶ Ejecutar Pruebas</button>
                    <button class="btn-reset" onclick="resetCode()">🔄 Resetear código</button>
                </div>

                <div id="consoleOutput" class="console">>_ Esperando ejecución...</div>
            </div>
        </div>
    </div>

    <!-- Lógica de ejecución evaluador múltiple -->
    <script>
        const retoId = <%= reto.id %>;
        // Inyectamos el string de código inicial original
        const rawInitialCode = <%- JSON.stringify(reto.codigo_inicial || '') %>;
        
        // Array de casos de prueba extraídos desde la Base de Datos
        const casosPrueba = <%- JSON.stringify(casosPrueba || []) %>;
        
        // Variables de retrocompatibilidad
        const defaultInput = <%- JSON.stringify(reto.test_input || '') %>;
        const defaultOutput = <%- JSON.stringify(reto.test_output || '') %>;

        function togglePista() {
            const x = document.getElementById("pista-box");
            x.style.display = (x.style.display === "block") ? "none" : "block";
        }

        function resetCode() {
            if (confirm("¿Estás seguro que deseas restablecer tu código? Perderás los cambios manuales.")) {
                document.getElementById('codeEditor').value = rawInitialCode;
                document.getElementById('consoleOutput').innerHTML = ">_ Código restablecido.\n";
            }
        }

        async function runCode() {
            const code = document.getElementById('codeEditor').value;
            const consoleDiv = document.getElementById('consoleOutput');
            const btnRun = document.querySelector('.btn-run');
            
            consoleDiv.innerHTML = ">_ Enviando a Judge0 para evaluación...\n";
            btnRun.disabled = true;

            let allTestsPassed = true;
            let testsToRun = [];

            // Usamos la tabla nueva de casos si existe para el reto
            if (casosPrueba && casosPrueba.length > 0) {
                testsToRun = casosPrueba;
            } else if (defaultInput) {
                testsToRun = [{ input: defaultInput, output_esperado: defaultOutput, es_visible: 1 }];
            }

            if (testsToRun.length === 0) {
                consoleDiv.innerHTML += "\n⚠️ No hay casos de prueba definidos en la base de datos para evaluar.";
                btnRun.disabled = false;
                return;
            }

            const lenguajeNombre = "<%= reto.lenguaje %>";
            const lenguajesIds = {
                "JavaScript": 63,
                "Python": 71,
                "Java": 62,
                "C++": 54,
                "C#": 51
            };
            const language_id = lenguajesIds[lenguajeNombre] || 63;

            let executionOutput = "\n--- RESULTADOS ---\n";
            let visibleCount = 1;
            let hiddenCount = 1;

            const globalStart = performance.now();

            try {
                // Iteramos TODOS los casos con Judge0 CE
                for (const test of testsToRun) {
                    let source_code = code;

                    // Envolver código según lenguaje
                    if (language_id === 62) { // Java
                        source_code = `import java.util.Scanner;\npublic class Main {\n${code}\n    public static void main(String[] args) {\n        Scanner scanner = new Scanner(System.in);\n        if(scanner.hasNextLine()){\n            String input = scanner.nextLine();\n            System.out.println(solucion(input));\n        }\n    }\n}`;
                    } else if (language_id === 71) { // Python
                        source_code = `${code}\nimport sys\nimport ast\ntry:\n    args = ast.literal_eval('[' + sys.stdin.read().strip() + ']')\nexcept:\n    args = eval('[' + sys.stdin.read().strip().replace('true', 'True').replace('false', 'False') + ']')\nprint(solucion(*args))`;
                    } else if (language_id === 63) { // JavaScript
                        source_code = `${code}\nconst fs = require('fs');\nconst input = fs.readFileSync(0, 'utf-8').trim();\nlet args;\ntry { args = eval('[' + input + ']'); } catch(e) { args = [input]; }\nconsole.log(solucion(...args));`;
                    } else if (language_id === 54) { // C++
                        source_code = `#include <iostream>\nusing namespace std;\n${source_code}\nint main() {\n    int n;\n    cin >> n;\n    cout << (solucion(n) ? "true" : "false") << endl;\n    return 0;\n}`;
                    }

                    const response = await fetch('https://ce.judge0.com/submissions?wait=true', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            source_code: source_code,
                            language_id: language_id,
                            stdin: test.input
                        })
                    });

                    const data = await response.json();

                    if (!data || !data.status) {
                        throw new Error('Judge0 no devolvió respuesta válida');
                    }

                    if (data.status.id !== 3) { // No Accepted (3)
                        allTestsPassed = false;
                        let errStr = data.compile_output || data.stderr || data.status.description;
                        if (test.es_visible === 1) {
                            executionOutput += `❌ Test Visible ${visibleCount} falló: ${errStr}\n`;
                            visibleCount++;
                        } else {
                            executionOutput += `❌ Test Oculto ${hiddenCount} falló en ejecución.\n`;
                            hiddenCount++;
                        }
                        continue;
                    }

                    // Limpiar stdout y esperado antes de comparar
                    let stdoutClear = (data.stdout || '').replace(/\\/g, '').replace(/"/g, '').trim();
                    let expectedClear = (test.output_esperado || '').replace(/\\/g, '').replace(/"/g, '').trim();

                    const isMatch = stdoutClear === expectedClear;

                    if (!isMatch) {
                        allTestsPassed = false;
                    }

                    if (test.es_visible === 1) {
                        const icon = isMatch ? "✅" : "❌";
                        executionOutput += `${icon} Test ${visibleCount}: Input: ${test.input} | Esperado: ${test.output_esperado} | Obtenido: ${data.stdout ? data.stdout.trim() : 'Vacío'}\n`;
                        visibleCount++;
                    } else {
                        if (!isMatch) {
                            executionOutput += `❌ Test Oculto ${hiddenCount} falló.\n`;
                        }
                        hiddenCount++;
                    }
                }

                const globalEnd = performance.now();
                const totalTime = (globalEnd - globalStart).toFixed(2);

                consoleDiv.innerHTML += executionOutput;

                if (allTestsPassed) {
                    consoleDiv.innerHTML += `\n🎉 ¡EL CÓDIGO PASÓ TODAS LAS PRUEBAS! (${totalTime}ms) 🎉\n`;
                } else {
                    consoleDiv.innerHTML += `\n⚠️ Fallaste algunas pruebas. Revisa tu intento.\n`;
                }

                // POST asíncrono para registrar el intento
                await fetch('/retos/enviar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reto_id: retoId,
                        codigo: code,
                        resultado: allTestsPassed ? 'Exitoso' : 'Fallido'
                    })
                });

                if (allTestsPassed) {
                    setTimeout(() => { window.location.reload(); }, 2000);
                }

            } catch (err) {
                consoleDiv.innerHTML += `\n❌ ERROR AL COMUNICARSE CON JUDGE0:\n${err.message}`;
                
                await fetch('/retos/enviar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reto_id: retoId, codigo: code, resultado: 'Fallido' })
                });
            } finally {
                btnRun.disabled = false;
            }
        }
    </script>
</body>
</html>